# --- LLM via OpenRouter ---
LLM_PROVIDER=custom
LLM_MODEL=openrouter/openai/gpt-4o-mini
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_INSTRUCTOR_MODE=tool_call
LLM_MAX_COMPLETION_TOKENS=4096
LLM_TEMPERATURE=0.0

# --- Our quiz call timeout (distinct from any cognee-internal LLM_TIMEOUT) ---
LLM_CALL_TIMEOUT_SECONDS=30.0

# --- Embeddings via OpenAI direct (raw openai SDK, not LiteLLM) ---
# `openai_compatible` routes through cognee's OpenAICompatibleEmbeddingEngine,
# which uses the raw openai SDK against the configured endpoint — avoiding
# LiteLLM's embedding provider-routing quirks. Works for OpenAI direct AND for
# any OpenAI-compatible provider (just swap EMBEDDING_ENDPOINT + API key + prefix
# the model name if the provider requires it). Do NOT use `EMBEDDING_PROVIDER=openai` —
# that dispatches to LiteLLM which needs an explicit `openai/` model prefix and
# can hang for 30s if misconfigured.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_ENDPOINT=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-REPLACE_ME
EMBEDDING_DIMENSIONS=1536

# --- Runtime ---
# DATA_ROOT_DIRECTORY is set from code (backend/.cognee_system) — do not override here
# unless you need a custom absolute path.
TELEMETRY_DISABLED=true
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false
COGNEE_CHUNKS_PER_BATCH=100
