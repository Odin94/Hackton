# --- LLM via OpenRouter ---
LLM_PROVIDER=custom
LLM_MODEL=openrouter/openai/gpt-4o-mini
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_INSTRUCTOR_MODE=tool_call
LLM_MAX_COMPLETION_TOKENS=4096
LLM_TEMPERATURE=0.0

# --- Our quiz call timeout (distinct from any cognee-internal LLM_TIMEOUT) ---
LLM_CALL_TIMEOUT_SECONDS=30.0

# --- Embeddings via OpenAI (LiteLLM route; required for cognee 1.0 here) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_KEY=sk-REPLACE_ME
EMBEDDING_DIMENSIONS=1536

# --- ElevenLabs (voice) ---
ELEVENLABS_API_KEY=sk-placeholder-replace-with-real-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Runtime ---
# DATA_ROOT_DIRECTORY is set from code (backend/.cognee_system) — do not override here
# unless you need a custom absolute path.
TELEMETRY_DISABLED=true
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false
COGNEE_CHUNKS_PER_BATCH=100
